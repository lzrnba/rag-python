# 服务配置
HOST=0.0.0.0
PORT=8000
DEBUG=True

# LLM 配置（Ollama）
LLM_MODEL=qwen2.5:7b
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama

# Embedding 配置（Ollama bge-m3）
EMBEDDING_MODEL=bge-m3:latest
EMBEDDING_DEVICE=cpu

# Reranker 配置
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANK_ENABLED=true
RERANK_CANDIDATES=20

# 向量库配置
VECTOR_STORE_PATH=E:\Project Design\project\python-rag\rag-python\data\vectorstore
DOCUMENTS_DIR=E:\Project Design\project\python-rag\rag-python\data\documents

# RAG 配置
MAX_ITERATIONS=3
TOP_K=5
VECTOR_WEIGHT=0.7
BM25_WEIGHT=0.3

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/rag.log

# Redis 配置（填入你的 Redis 连接信息）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
